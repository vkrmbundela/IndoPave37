# Set this in GitHub Actions repository variables for production builds if pointing to a custom backend.
# If left empty, it defaults to the local running FastAPI server at http://127.0.0.1:8000.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: GitHub Pages repository path base.
# For username.github.io/repo-name, use /repo-name/
VITE_BASE_PATH=/your-repo-name/
